#!/bin/bash
# Create a PR for a formula bump. Commits, pushes, and opens the PR.
#
# Usage: script/create-bump-pr <formula-file> <package> <version>
set -euo pipefail

file="$1"
package="$2"
version="$3"

branch="bump-${package}-${version}"

git checkout -b "$branch"
git add "$file"
git commit -m "Bump $package to $version"
git push -u origin "$branch"

gh pr create \
  --title "Bump $package to $version" \
  --body "Automated version bump from livecheck." \
  --head "$branch"
